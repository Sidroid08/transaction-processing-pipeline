# Copy to .env to override defaults. Everything works WITHOUT this file.

# --- LLM configuration ---
# provider: auto | gemini | stub
#   auto  -> use Gemini if GEMINI_API_KEY is set, else the local deterministic stub
#   gemini-> force Gemini (requires GEMINI_API_KEY)
#   stub  -> force the offline deterministic classifier (no network, no key)
LLM_PROVIDER=auto

# Free-tier Gemini key (https://aistudio.google.com/app/apikey). Optional.
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-flash

# --- Infra (defaults already point at the compose services) ---
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/transactions
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1
